# ==========================================
# 股票看板 环境变量模板
# 复制为 .env 后填入真实值
# ==========================================

# Tushare（行情 / 财务数据）
TUSHARE_TOKEN=你的Tushare_Token
TUSHARE_URL=你的Tushare代理地址

# DeepSeek（AI 分析）
DEEPSEEK_API_KEY=你的DeepSeek_API_Key

# Investoday（一致预期 / 基本面）
INVESTO_KEY=你的Investoday_key

# 数据缓存目录
PERSIST_DIR=./persist
